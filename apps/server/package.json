{
  "name": "@waxonedge/server",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start_deamon": "node --import tsx --max-old-space-size=2048 deamon.js",
    "start_deamon_bigmem": "node --import tsx --max-old-space-size=4096 deamon.js",
    "start_deamon_inspect": "node --import tsx --inspect=0.0.0.0:9229 deamon.js",
    "start_api": "node --import tsx api.js",
    "start_logodownloader": "node --import tsx logo_downloader.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@alcorexchange/alcor-swap-sdk": "1.0.24",
    "@waxonedge/api-contracts": "workspace:*",
    "@waxonedge/antelope-ship-reader": "workspace:*",
    "@wharfkit/antelope": "1.2.0",
    "@wharfkit/contract": "0.4.3",
    "axios": "0.27.2",
    "body-parser": "1.20.5",
    "dotenv": "16.6.1",
    "express": "4.22.2",
    "http-proxy-middleware": "2.0.10",
    "knex": "2.5.1",
    "pg": "8.21.0",
    "rate-limiter-flexible": "5.0.5",
    "redis": "4.7.1",
    "rxjs": "6.6.7",
    "socket.io": "4.8.3",
    "uuid": "9.0.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "tsx": "4.22.4"
  },
  "devDependencies": {
    "@types/node": "25.9.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
