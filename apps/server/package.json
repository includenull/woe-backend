    "@blockmatic/tsconfig": "2.0.0",
    "@types/node": "25.9.4",
    "all-contributors-cli": "6.26.1",
    "denoify": "1.6.17",
    "eslint": "7",
    "husky": "7.0.4",
    "lint-staged": "11.2.6",
    "prettier": "2.8.8",
