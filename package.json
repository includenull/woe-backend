{
  "name": "waxonedge",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "lint": "prettier --check \"**/*.{ts,tsx}\" && eslint \"**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx}\" && eslint \"**/*.{ts,tsx}\" --fix",
    "test": "pnpm -r test",
    "dev:web": "pnpm --filter @waxonedge/web dev",
    "server:api": "pnpm --filter @waxonedge/server start_api"
  },
  "resolutions": {
    "@wharfkit/antelope": "1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "prettier": "3.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.1.9"
  }
}